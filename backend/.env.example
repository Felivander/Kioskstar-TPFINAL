# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/kioskstar?schema=public"

# JWT — OBLIGATORIO: generar con: openssl rand -base64 64
# NUNCA usar valores por defecto en producción
JWT_SECRET="REEMPLAZAR_CON_UN_SECRET_ALEATORIO_DE_64_BYTES"

# Frontend URL — para CORS (CRIT-3)
# En desarrollo: http://localhost:5173
# En producción: https://tu-dominio.com
FRONTEND_URL="http://localhost:5173"

# MercadoPago
MERCADOPAGO_ACCESS_TOKEN=""

# Google Maps — RESTRINGIR en Google Cloud Console a HTTP referrers específicos
GOOGLE_MAPS_API_KEY=""

# AI Vision
ANTHROPIC_API_KEY=""

# Email (Resend)
RESEND_API_KEY=""

# Server
PORT=3000
